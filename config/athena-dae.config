# ============================================================
# JDCloud Athena AX6600 / RE-CS-02
# DAE + integrated BTF + NSS-safe profile
# ============================================================

# ---------- Target ----------
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# ---------- Build / CPU / memory ----------
CONFIG_CCACHE=y
CONFIG_DEVEL=y
CONFIG_KERNEL_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_ATH11K_MEM_PROFILE_1G=y
CONFIG_IPQ_MEM_PROFILE_1024=y

# ---------- LuCI ----------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-app-firewall=n
CONFIG_PACKAGE_luci-app-firewall4=y
CONFIG_PACKAGE_firewall4=y

# ---------- DAE kernel requirements ----------
CONFIG_KERNEL_BPF_SYSCALL=y
CONFIG_KERNEL_BPF_JIT=y
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_CGROUP_BPF=y
CONFIG_KERNEL_KPROBES=y
CONFIG_KERNEL_KPROBE_EVENTS=y
CONFIG_KERNEL_BPF_EVENTS=y
CONFIG_KERNEL_BPF_STREAM_PARSER=y
CONFIG_KERNEL_NET_INGRESS=y
CONFIG_KERNEL_NET_EGRESS=y
CONFIG_KERNEL_NET_CLS_ACT=y
CONFIG_KERNEL_DEBUG_INFO=y
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set
CONFIG_KERNEL_DEBUG_INFO_BTF=y
CONFIG_KERNEL_DEBUG_INFO_BTF_MODULES=y
CONFIG_KERNEL_XDP_SOCKETS=y

CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-bpf=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-xdp-sockets-diag=y

# ---------- DAE + LuCI ----------
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y
CONFIG_PACKAGE_dae=y
CONFIG_DAE_USE_KERNEL_BTF=y
# CONFIG_DAE_USE_VMLINUX_BTF is not set
CONFIG_PACKAGE_luci-app-daede=y
CONFIG_PACKAGE_luci-app-daede_dae=y
# CONFIG_PACKAGE_luci-app-daede_daed is not set
# CONFIG_PACKAGE_daed is not set

# ---------- NSS ----------
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y

# ECM 可能让流量绕过 DAE 的 TC/eBPF 钩子：
# 构建成匹配内核的 IPK，但默认不装入固件。
CONFIG_PACKAGE_kmod-qca-nss-ecm=m

# ---------- nftables only; no legacy iptables / flow offload ----------
CONFIG_PACKAGE_kmod-nf-ipt=n
CONFIG_PACKAGE_iptables=n
CONFIG_PACKAGE_kmod-nft-compat=n
CONFIG_PACKAGE_kmod-nft-fullcone=n
CONFIG_PACKAGE_kmod-nft-offload=n
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-xfrm=y

# ---------- Athena hardware ----------
CONFIG_PACKAGE_kmod-dsa=y
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-sdhci=y
CONFIG_PACKAGE_kmod-sdhci-msm=y
CONFIG_PACKAGE_luci-app-athena-led=y
CONFIG_PACKAGE_athena-led-control=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_luci-app-wireless-regdb=y
CONFIG_PACKAGE_skb_recycler=n

# ---------- eMMC / maintenance ----------
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-mountd=y
CONFIG_PACKAGE_luci-app-partexp=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_tune2fs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_gdisk=y
CONFIG_PACKAGE_lsblk=y

# ---------- Useful diagnostics ----------
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-wolplus=y

# ---------- Deliberately excluded proxy stacks ----------
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-passwall2=n
CONFIG_PACKAGE_luci-app-openclash=n
CONFIG_PACKAGE_luci-app-homeproxy=n
CONFIG_PACKAGE_luci-app-mosdns=n
CONFIG_PACKAGE_luci-app-smartdns=n
CONFIG_PACKAGE_luci-app-adguardhome=n
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_dockerd=n
CONFIG_PACKAGE_luci-app-samba4=n

# ---------- Remove unnecessary modem/audio extras ----------
CONFIG_PACKAGE_kmod-sound-core=n
CONFIG_PACKAGE_kmod-usb-audio=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-fibocom=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-quectel=n
CONFIG_PACKAGE_kmod-usb-net-sierrawireless=n
